    {
      "key": {
        "uuid": "6eabccdb_86bcdfae",
        "filename": "resultdb/sink/artifact_uploader.go",
        "patchSetId": 9
      },
      "lineNbr": 37,
      "author": {
        "id": 1147264
      },
      "writtenOn": "2020-06-23T06:58:29Z",
      "side": 1,
      "message": "I changed the function signature of Upload such that it takes a slice of bytes, instead of io.ReadSeeker. If Upload takes io.Reader or io.ReadSeeker, users can still pass *os.File, but because Upload completely hides the HTTP request used inside, users have no way to set GetBody().\n\nThis module now provides Upload() and UploadFromFile(). If users want to upload an artifact from a file, then they can simply pass the file path to UploadFromFile. Then, UploadFromFile will set GetBody() automatically. Let me know if you have different ideas.",
      "parentUuid": "5e04aff6_2fbe4409",
      "range": {
        "startLine": 37,
        "startChar": 5,
        "endLine": 37,
        "endChar": 21
      },
      "revId": "b0e99fd5cd650e4dd1a4e8b079393b46a692cb90",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": false
    },
    {
      "key": {
        "uuid": "36ce9f73_2d36a3c3",
        "filename": "resultdb/sink/artifact_uploader.go",
        "patchSetId": 9
      },
      "lineNbr": 50,
      "author": {
        "id": 1114299
      },
      "writtenOn": "2020-06-19T22:40:49Z",
      "side": 1,
      "message": "why is it public?",
      "range": {
        "startLine": 50,
        "startChar": 27,
        "endLine": 50,
        "endChar": 28
      },
      "revId": "b0e99fd5cd650e4dd1a4e8b079393b46a692cb90",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
