    {
      "key": {
        "uuid": "5b601e8a_3eeeeef1",
        "filename": "resultdb/sink/artifact_uploader.go",
        "patchSetId": 9
      },
      "lineNbr": 50,
      "author": {
        "id": 1147264
      },
      "writtenOn": "2020-06-22T21:02:38Z",
      "side": 1,
      "message": "The original intent was that the user of this function can keep a original copy of the HTTP request so that it can be reused on retries without having to calculate the hash again.\n\nIn ResultSink, dispatcher already implements retries on transient errors, and I wanted to rely on the retry performed on dispatcher, because the dispatcher worker could process another batch, while the temporarily failed batch was held with a retry delay.\n\nHowever, now I think it\u0027s unnecessary complication, and upload functions retry requests on transient failures by themselves. As a result, if a transient failure happens for a long period, like a minute, then it will hold the dispatcher worker during the retry delays.",
      "parentUuid": "36ce9f73_2d36a3c3",
      "range": {
        "startLine": 50,
        "startChar": 27,
        "endLine": 50,
        "endChar": 28
      },
      "revId": "b0e99fd5cd650e4dd1a4e8b079393b46a692cb90",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": false
    },
