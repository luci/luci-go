      "writtenOn": "2021-01-22T21:41:41Z",
      "side": 1,
      "message": "I have a feeling we may need to convert this to a callback in the future. A prpc.Client can be reused when calling multiple different servers, some supporting compression some not.",
      "range": {
        "startLine": 127,
        "startChar": 1,
        "endLine": 127,
        "endChar": 25
      },
      "revId": "e3182437d0e549c65127cfe28eda34acd09a7b24",
