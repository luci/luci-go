        "uuid": "9617c604_31ea7fa9",
        "filename": "gce/appengine/config/config.go",
        "patchSetId": 1
      },
      "lineNbr": 143,
      "author": {
        "id": 1003211
      },
      "writtenOn": "2019-02-27T00:16:42Z",
      "side": 1,
      "message": "It\u0027s not necessary given how merge is actually used, but in general I believe a versatile function that properly handles all edge cases should have this. One would expect merge(context.Background, \u0026Config{}) to work.",
      "parentUuid": "24d6b083_46730d59",
      "range": {
        "startLine": 143,
        "startChar": 26,
        "endLine": 143,
        "endChar": 35
      },
      "revId": "9b42c4d0d9ad2659dbfca0257bd7c12babc80d74",
