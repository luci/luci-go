      "lineNbr": 48,
      "author": {
        "id": 1003211
      },
      "writtenOn": "2019-02-27T00:16:42Z",
      "side": 1,
      "message": "Because it\u0027s the union of all config files. kinds.cfg\u0027s top-level message Kinds currently only has repeated Kind kind, but that may or may not be true for all config files, and all future config files.",
      "parentUuid": "f32d8b8e_bb0dd0f1",
      "range": {
        "startLine": 48,
        "startChar": 7,
        "endLine": 48,
        "endChar": 17
      },
      "revId": "9b42c4d0d9ad2659dbfca0257bd7c12babc80d74",
