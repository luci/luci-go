        "patchSetId": 4
      },
      "lineNbr": 270,
      "author": {
        "id": 1114919
      },
      "writtenOn": "2021-06-17T21:24:21Z",
      "side": 1,
      "message": "My thinking is that we care only if delay is \u003e1, probably \u003e10s,\nso 1s precision is good enough, Besides, DS transactions with writes take at least 100ms, so ms precision is 90% useless anyway.",
      "parentUuid": "135bfc12_81612ecf",
      "range": {
        "startLine": 270,
        "startChar": 6,
        "endLine": 270,
        "endChar": 45
      },
      "revId": "e16ba24d55f0d4828e61d591f0aa98a44ba8f18f",
