      "writtenOn": "2018-12-01T02:54:44Z",
      "side": 1,
      "message": "No, it makes sense :)\nAs a gerrit admin, i routinely edit refs/meta/config.\nAnd most chromium browser devs constantly cherry pick their fixes for releases in refs/branch-heads/* (in chromium/src and other repos)",
      "parentUuid": "dd2e5b9b_bb1e1e6c",
      "range": {
        "startLine": 188,
        "startChar": 9,
        "endLine": 188,
