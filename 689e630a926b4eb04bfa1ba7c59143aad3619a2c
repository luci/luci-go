        "id": 1157909
      },
      "writtenOn": "2020-09-12T05:36:16Z",
      "side": 1,
      "message": "I got confused by the timeline of purging uninteresting results (2 months) with purging all results (2 years). And now I think we shouldn\u0027t even allow querying history for older than 2 months, otherwise we\u0027ll return partial history with interesting results only.",
      "parentUuid": "1c016896_0087e3de",
      "range": {
        "startLine": 134,
        "startChar": 5,
        "endLine": 134,
        "endChar": 29
      },
      "revId": "689e630a926b4eb04bfa1ba7c59143aad3619a2c",
