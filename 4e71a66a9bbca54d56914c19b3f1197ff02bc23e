    {
      "key": {
        "uuid": "6c65b1dc_cf9b298c",
        "filename": "scheduler/appengine/engine/controller.go",
        "patchSetId": 1
      },
      "lineNbr": 206,
      "author": {
        "id": 1002539
      },
      "writtenOn": "2018-06-27T02:19:19Z",
      "side": 0,
      "message": "Implicit deadline is 10 min.\n\nI want us to:\n1. Notice that some calls are slower than 1 min.\n2. Still allow urlfetch tasks to run longer than 1 min, if they are configured so.\n\nSo if we set default task deadline to 1 min, we won\u0027t allow (2). If we set it to something high, we won\u0027t notice (1), since we will not be getting HTTP 500s.",
      "parentUuid": "4495c2f9_ddbe6691",
      "revId": "4e71a66a9bbca54d56914c19b3f1197ff02bc23e",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
