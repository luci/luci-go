      "lineNbr": 71,
      "author": {
        "id": 1002539
      },
      "writtenOn": "2019-08-22T18:48:38Z",
      "side": 1,
      "message": "does this allow \u0027\\\u0027? Is it system-global or user-specific namespace?",
      "range": {
        "startLine": 71,
        "startChar": 14,
        "endLine": 71,
        "endChar": 18
