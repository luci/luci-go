    {
      "key": {
        "uuid": "a15f1135_676ac0e4",
        "filename": "logdog/client/butlerlib/streamclient/client.go",
        "patchSetId": 4
      },
      "lineNbr": 71,
      "author": {
        "id": 1001907
      },
      "writtenOn": "2019-08-22T23:01:35Z",
      "side": 1,
      "message": "The named pipe namespace is global (well, local to the machine).  \"\\\\machine\\pipe\\name\" is also a named pipe, but this protocol prepends \"\\\\.\\pipe\\\" to \"name\" to ensure that it\u0027s always machine local.",
      "parentUuid": "1a661b69_8104053c",
      "range": {
        "startLine": 71,
        "startChar": 14,
        "endLine": 71,
        "endChar": 18
      },
