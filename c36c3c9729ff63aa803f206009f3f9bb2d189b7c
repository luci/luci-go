      "writtenOn": "2018-01-11T21:17:16Z",
      "side": 1,
      "message": "description is usually longer than name, but both have same max length. It seems that either name field allows too long strings, or this one is insufficient",
      "range": {
        "startLine": 27,
        "startChar": 21,
        "endLine": 27,
        "endChar": 24
