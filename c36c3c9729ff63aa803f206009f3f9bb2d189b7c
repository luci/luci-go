    {
      "key": {
        "uuid": "bb2efa2b_d5e7260e",
        "filename": "machine-db/appengine/database/setup/migrations/005_initialize_machines.up.sql",
        "patchSetId": 1
      },
      "lineNbr": 27,
      "author": {
        "id": 1003211
      },
      "writtenOn": "2018-01-12T00:33:06Z",
      "side": 1,
      "message": "The existing descriptions that users have to describe their entities are very short, so it\u0027s possible name fields are too long. However, varchar space usage is proportional to the length of the contained value, so it\u0027s not like space is being wasted by having varchar(255) where varchar(32) may suffice (I\u0027m not even sure if it would).\n\nI can try to figure out exactly what length is needed for each field later on, but it\u0027s not a priority right now.",
      "parentUuid": "28312275_d388bef6",
      "range": {
