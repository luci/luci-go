    {
      "key": {
        "uuid": "143c774a_47558323",
        "filename": "resultdb/sink/artifact_uploader.go",
        "patchSetId": 14
      },
      "lineNbr": 116,
      "author": {
        "id": 1001907
      },
      "writtenOn": "2020-06-24T18:21:40Z",
      "side": 1,
      "message": "I believe that http is documented as closing the body even on error?",
      "parentUuid": "049e4f4d_e252697c",
      "revId": "703e004cf80296ba86af00a458dc07080a646505",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
    {
      "key": {
        "uuid": "329ca7e9_7d4dfc0a",
        "filename": "resultdb/sink/artifact_uploader.go",
        "patchSetId": 14
      },
      "lineNbr": 116,
      "author": {
        "id": 1147264
      },
      "writtenOn": "2020-06-24T23:26:51Z",
      "side": 1,
      "message": "Yes, http.Client is responsible for calling the Close method.\nhttps://golang.org/src/net/http/request.go#L177",
      "parentUuid": "143c774a_47558323",
      "revId": "703e004cf80296ba86af00a458dc07080a646505",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": false
    },
    {
      "key": {
        "uuid": "9b79b995_0e80ade7",
        "filename": "resultdb/sink/artifact_uploader.go",
        "patchSetId": 14
      },
      "lineNbr": 116,
      "author": {
        "id": 1114299
      },
      "writtenOn": "2020-06-24T23:41:22Z",
      "side": 1,
      "message": "there is no guarantee that http.Client.Do is called to begin with, e.g. L119",
      "parentUuid": "329ca7e9_7d4dfc0a",
      "revId": "703e004cf80296ba86af00a458dc07080a646505",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
    {
      "key": {
        "uuid": "40d6ebbf_6a630027",
        "filename": "resultdb/sink/artifact_uploader.go",
