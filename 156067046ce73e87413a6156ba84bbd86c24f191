      "writtenOn": "2020-01-09T19:49:15Z",
      "side": 1,
      "message": "What if this was only filled when supplying fetch_url, too? If it\u0027s a datastream then rdb could populate it on fetch from the current state of the datastream.",
      "parentUuid": "f33206ce_ca52ef70",
      "range": {
        "startLine": 174,
        "startChar": 8,
        "endLine": 174,
        "endChar": 12
      },
      "revId": "156067046ce73e87413a6156ba84bbd86c24f191",
