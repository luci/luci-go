    {
      "key": {
        "uuid": "9e96ddb0_49f9c721",
        "filename": "machine-db/appengine/model/datacenters/datacenters.go",
        "patchSetId": 2
      },
      "lineNbr": 116,
      "author": {
        "id": 1003211
      },
      "writtenOn": "2017-11-18T00:56:41Z",
      "side": 1,
      "message": "It\u0027s a good idea and I\u0027ll try it, but I\u0027m worried about making SQL statement composition too complex. As mentioned above, we have no tests that the SQL statements we execute are actually correct. I haven\u0027t found a good in-memory MySQL database package that we could use to verify both Go and SQL are correct. Therefore I\u0027m trying to keep each prepared and executed SQL statement as obvious and readable a string as possible.",
      "parentUuid": "7f0bc37c_5fd81d10",
      "revId": "4ac64e9835cdc5fa6b35137797a21dd99ad2254e",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
