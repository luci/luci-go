      },
      "writtenOn": "2017-10-12T01:03:51Z",
      "side": 1,
      "message": "Yeah, that can get laid out automatically for sure.",
      "parentUuid": "81bda384_45165abb",
      "range": {
        "startLine": 49,
        "startChar": 8,
