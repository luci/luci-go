    },
    {
      "key": {
        "uuid": "070d11eb_62b8220e",
        "filename": "milo/api/config/project.proto",
        "patchSetId": 2
      },
      "lineNbr": 74,
      "author": {
        "id": 1154295
      },
      "writtenOn": "2017-10-12T01:03:51Z",
      "side": 1,
      "message": "It\u0027s probably do-able to use some heuristic to \"balance\" out the columns, but I don\u0027t think it\u0027ll ever turn out as nice as just letting the user have full control over the layout. Different projects have different requirements, and I think we would benefit from having more layout options. That also makes the rendering itself much more straight-forward. :)",
      "parentUuid": "e9267baf_039f1e80",
      "range": {
        "startLine": 74,
        "startChar": 10,
        "endLine": 74,
        "endChar": 16
      },
      "revId": "5c1bbf3c067ba443b5b852bbac2a7fa33634bd90",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
