      "writtenOn": "2017-10-12T00:36:06Z",
      "side": 1,
      "message": "Also considering: removing column and let the renderer do all the layout automatically.  Such that header becomes just a long list of entries.  Not sure if that\u0027s doable though.",
      "range": {
        "startLine": 74,
        "startChar": 10,
        "endLine": 74,
        "endChar": 16
      },
      "revId": "5c1bbf3c067ba443b5b852bbac2a7fa33634bd90",
