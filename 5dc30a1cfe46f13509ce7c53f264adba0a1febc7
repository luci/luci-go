    {
      "key": {
        "uuid": "978412a1_0b02c80e",
        "filename": "machine-db/appengine/frontend/settings.go",
        "patchSetId": 7
      },
      "lineNbr": 71,
      "author": {
        "id": 1002539
      },
      "writtenOn": "2017-11-01T22:58:19Z",
      "side": 1,
      "message": "this is not necessary, go knows how to type-cast literals to appropriate compatible types. template.HTML and string are compatible (see https://golang.org/pkg/html/template/#HTML), so \"\u003cp\u003eServer ...\" is silently getting type cast to template.HTML.\n\nThis works only for literals though, e.g. following will not work:\n\ns :\u003d \"stuff\"\nf :\u003d settings.UIField{\n  Help: s, // error, s is \u0027string\u0027, not \u0027template.HTML\u0027\n}",
      "range": {
        "startLine": 71,
        "startChar": 10,
        "endLine": 71,
        "endChar": 24
      },
      "revId": "5dc30a1cfe46f13509ce7c53f264adba0a1febc7",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
