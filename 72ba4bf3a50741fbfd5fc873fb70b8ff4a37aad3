      },
      "lineNbr": 48,
      "author": {
        "id": 1114299
      },
      "writtenOn": "2018-04-17T17:31:45Z",
      "side": 1,
      "message": "\u003e swarming host is another dimension.\n\nThis is a very good abstraction to me. Perhaps you could simplify the whole thing by having\n\n  type PoolDescriptor strpair.Map\n\n  const SwarmingHostnameKey \u003d \"swarming_hostname\"\n\nPoolDescriptor SGTM",
      "parentUuid": "ab39ec08_39883626",
      "range": {
        "startLine": 47,
        "startChar": 1,
        "endLine": 48,
        "endChar": 12
      },
      "revId": "72ba4bf3a50741fbfd5fc873fb70b8ff4a37aad3",
