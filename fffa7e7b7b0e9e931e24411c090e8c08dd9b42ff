      "writtenOn": "2020-11-15T20:08:23Z",
      "side": 1,
      "message": "*major #1*: hm, so this will be called for every project as well as at the beginning of the cronjob.\nCan the fact that project was found in LUCI config in CronHandler be propagated into the tq.Task payload to avoid this extra call?",
      "range": {
        "startLine": 120,
        "startChar": 2,
        "endLine": 120,
        "endChar": 68
      },
      "revId": "fffa7e7b7b0e9e931e24411c090e8c08dd9b42ff",
