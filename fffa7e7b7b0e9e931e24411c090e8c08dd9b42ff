      "lineNbr": 120,
      "author": {
        "id": 1381059
      },
      "writtenOn": "2020-11-16T08:14:34Z",
      "side": 1,
      "message": "I think it result in with potential race. i.e\n\n  T1: submit refresh task with project foo found in LUCI Config\n  T2: project foo is deregistered\n  T3: CV start executing the task and think project foo is still alive.",
      "parentUuid": "706e6157_b29a0352",
      "range": {
        "startLine": 120,
        "startChar": 2,
        "endLine": 120,
        "endChar": 68
      },
      "revId": "fffa7e7b7b0e9e931e24411c090e8c08dd9b42ff",
