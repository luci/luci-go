    {
      "key": {
        "uuid": "9c145b3d_b21d53c0",
        "filename": "luci_notify/notify/builder_state.go",
        "patchSetId": 1
      },
      "lineNbr": 105,
      "author": {
        "id": 1154295
      },
      "writtenOn": "2017-09-19T22:13:12Z",
      "side": 1,
      "message": "My thought was that we can cover the edge case of having a new build. So, for example, if somebody just puts up a configuration for \"on_change\" (which I suspect will be the most popular option...) and immediately get notified about a UNKNOWN -\u003e SUCCESS transition, it might feel a bit broken, especially if the builder already has a long history. It\u0027s very minor, but I feel like it would be noticeable enough that users might say something.\n\nI\u0027ll remove it though if you still feel like it will be too much extra complexity to manage, or that it won\u0027t really be a big deal.",
      "parentUuid": "76046396_149af225",
      "range": {
        "startLine": 105,
        "startChar": 17,
        "endLine": 105,
        "endChar": 34
      },
      "revId": "9a7933ca5363d169e08873522de5a29bca832ec5",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
