mac:
	GOOS=darwin GOARCH=amd64 go build -o isolate_mac ../../isolate
	GOOS=darwin GOARCH=amd64 go build -o isolated_mac  ../../isolated

linux:
	GOOS=linux GOARCH=amd64 go build -o isolate_linux ../../isolate
	GOOS=linux GOARCH=amd64 go build -o isolated_linux ../../isolated

win:
	GOOS=windows GOARCH=amd64 go build -o isolate_win.exe ../../isolate
	GOOS=windows GOARCH=amd64 go build -o isolated_win.exe ../../isolated
