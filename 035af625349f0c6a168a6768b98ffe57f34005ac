      "writtenOn": "2020-10-08T21:25:12Z",
      "side": 1,
      "message": "we have a goroutine leak here.\nwe need to cancel Go\u0027s ctx in this case",
      "range": {
        "startLine": 93,
        "startChar": 2,
        "endLine": 93,
        "endChar": 75
      },
      "revId": "035af625349f0c6a168a6768b98ffe57f34005ac",
