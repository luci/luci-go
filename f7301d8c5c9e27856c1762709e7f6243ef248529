        "id": 1002539
      },
      "writtenOn": "2018-05-17T21:59:04Z",
      "side": 1,
      "message": "Consider parallelizing this. There are many LUCI projects. And there may be many templates in each project (fetched sequentially), and LUCI config sometimes hangs for 5-10 sec. So updating all projects sequentially may take a lot of time.\n\nThis shouldn\u0027t be too hard with parallel.FanOutIn.",
      "range": {
        "startLine": 180,
        "startChar": 1,
        "endLine": 180,
        "endChar": 30
      },
      "revId": "f7301d8c5c9e27856c1762709e7f6243ef248529",
