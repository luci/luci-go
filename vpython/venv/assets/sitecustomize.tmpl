# This file is injected by `vpython` in order for scripts run in this virtualenv
# via vpython to circle back to the vpython binary which invoked them. This
# allows python scripts invoked by vpython in some environment "X" to invoke
# other scripts, using sys.executable, in environment "Y", simply by using
# sys.executable.
def _init():
  key = '_VPYTHON_EXE'
  import sys, os
  if key in os.environ:
    sys.real_executable = sys.executable
    sys.executable = os.environ.pop(key)

_init()
