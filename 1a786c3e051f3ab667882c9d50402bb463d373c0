      "writtenOn": "2019-01-30T01:58:51Z",
      "side": 1,
      "message": "given that you know these are all digits, i\u0027d instead complain that int is too large + add extra check based on L59 comment can be inlined into here.",
      "revId": "1a786c3e051f3ab667882c9d50402bb463d373c0",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
