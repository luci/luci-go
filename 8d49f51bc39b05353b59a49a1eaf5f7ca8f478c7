    {
      "key": {
        "uuid": "54678226_fe082806",
        "filename": "server/tq/dispatcher.go",
        "patchSetId": 2
      },
      "lineNbr": 481,
      "author": {
        "id": 1002539
      },
      "writtenOn": "2020-07-30T06:44:24Z",
      "side": 1,
      "message": "Locking read-write mutex for reading when nothing is writing is essentially free. I prefer simpler API without Finalize/Freeze to saving 1 nanosecond (just launching WorkPool probably takes 10000 times more time). For the same reason I don\u0027t really have New(...) or Initialize(...): you just populate fields of Dispatcher and off to the races (no put intended). I strive to make such APIs, they are harder to misuse.\n\n\u003e On pods/services where InstallRoutes is called, that\u0027s a natural boundary.\n\nIt is not. InstallRoutes may be called either before (if tasks are registered in server.Main(...)) or after (it tasks are registered during init() time).",
      "parentUuid": "ba0fb5ca_a1caeec3",
      "range": {
        "startLine": 478,
        "startChar": 1,
        "endLine": 481,
        "endChar": 2
      },
      "revId": "8d49f51bc39b05353b59a49a1eaf5f7ca8f478c7",
