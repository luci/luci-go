      "writtenOn": "2020-08-22T07:03:29Z",
      "side": 1,
      "message": "this doesn\u0027t prevent the user to specify status 950934, or any other number. Should we have an allowlist of statuses?\ne.g. ENDMASK isn\u0027t allowed either",
      "range": {
        "startLine": 132,
        "startChar": 6,
