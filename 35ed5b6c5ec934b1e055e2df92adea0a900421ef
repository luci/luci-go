    {
      "key": {
        "uuid": "e4ca1fe4_054dd71c",
        "filename": "common/auth/internal/luci_ctx.go",
        "patchSetId": 1
      },
      "lineNbr": 166,
      "author": {
        "id": 1002539
      },
      "writtenOn": "2017-09-23T00:52:49Z",
      "side": 1,
      "message": "\"\" is for cases when we can potentially grab an email, but haven\u0027t tried yet. NoEmail is more correct here, since no matter how many times we call RefreshToken/MintToken, the email won\u0027t appear out of nothing.\n\nAlso, this provider is marked as \"Lightweight\" as well, which means we don\u0027t need to care about the on-disk token cache. All tokens will be cached in memory, \"-\" will not be dropped to disk. (Which means after we deploy binaries that understand emails in LUCI_CONTEXT, they\u0027ll correctly pick it up).",
      "parentUuid": "d4ab0066_d60f6f2e",
      "range": {
        "startLine": 166,
        "startChar": 18,
