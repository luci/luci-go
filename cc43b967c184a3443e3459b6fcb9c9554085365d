        "id": 1134874
      },
      "writtenOn": "2017-11-15T23:14:11Z",
      "side": 1,
      "message": "How can I validate this URL from console.html template? That is, if I use something like #invalid-build, is there any thing I can or should do from console.html? Presently it just takes the result of generating the URL and stuffs it in href.",
      "parentUuid": "0ca470b0_68f05eff",
      "range": {
        "startLine": 36,
        "startChar": 3,
        "endLine": 36,
        "endChar": 58
      },
      "revId": "cc43b967c184a3443e3459b6fcb9c9554085365d",
