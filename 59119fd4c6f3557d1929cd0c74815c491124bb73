      "writtenOn": "2018-03-13T23:10:37Z",
      "side": 1,
      "message": "oh.\n\nwhy is it wrong otherwise? Go code usually uses zero time to indicate absence of time. unix epoch is not zero, so some other parts of the code may break?",
      "parentUuid": "7fffa666_bbb5412c",
      "range": {
        "startLine": 156,
        "startChar": 46,
        "endLine": 156,
        "endChar": 56
      },
      "revId": "59119fd4c6f3557d1929cd0c74815c491124bb73",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
