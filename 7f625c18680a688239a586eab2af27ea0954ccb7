      },
      "writtenOn": "2020-07-20T23:41:30Z",
      "side": 1,
      "message": "why does it have to be rate limiting exactly (vs a semaphore for concurrency limiting to avoid OOMs)?",
      "range": {
        "startLine": 256,
        "startChar": 75,
        "endLine": 256,
        "endChar": 84
      },
      "revId": "7f625c18680a688239a586eab2af27ea0954ccb7",
