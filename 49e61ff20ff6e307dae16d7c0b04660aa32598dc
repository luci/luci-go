      },
      "writtenOn": "2017-12-19T14:18:28Z",
      "side": 1,
      "message": "WDYT about moving this to \"venv\" as a function: \"IsVirtualEnvBinDir(path)\"?",
      "range": {
        "startLine": 115,
        "startChar": 1,
        "endLine": 115,
        "endChar": 71
      },
      "revId": "49e61ff20ff6e307dae16d7c0b04660aa32598dc",
