      "writtenOn": "2020-11-24T21:25:14Z",
      "side": 1,
      "message": "I really want to remove this. We never ever used it, and it adds some non-trivial complexity to how dscache will be initialized on non-GAE (where we usually initialize services only in the root context, not in per-request contexts).",
      "range": {
        "startLine": 46,
        "startChar": 5,
        "endLine": 46,
        "endChar": 22
      },
      "revId": "1b1a3cb3b4be99acc1d96eb8e18ca12571fc9d6b",
