    },
    {
      "key": {
        "uuid": "9728fa59_e0645d42",
        "filename": "common/gcloud/iam/client.go",
        "patchSetId": 11
      },
      "lineNbr": 208,
      "author": {
        "id": 1307247
      },
      "writtenOn": "2018-10-10T18:31:14Z",
      "side": 1,
      "message": "TokenType is not part of the API protocol, so changed to set tokenType explicitly in the final token struct.",
      "parentUuid": "e2efdf58_9e655071",
      "range": {
        "startLine": 208,
        "startChar": 2,
        "endLine": 208,
        "endChar": 20
      },
      "revId": "183177108876b22e37a1e6db0b5907fe6173bd69",
