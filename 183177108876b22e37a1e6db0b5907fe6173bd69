        "id": 1002539
      },
      "writtenOn": "2018-10-10T01:03:12Z",
      "side": 1,
      "message": "does this need `json:\"tokenType\"` annotation? I think by default Go will be searching for \"TokenType\" JSON field, and not finding it.",
      "range": {
        "startLine": 208,
        "startChar": 2,
        "endLine": 208,
        "endChar": 20
      },
      "revId": "183177108876b22e37a1e6db0b5907fe6173bd69",
