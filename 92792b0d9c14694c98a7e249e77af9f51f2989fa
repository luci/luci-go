      "writtenOn": "2019-10-05T00:27:39Z",
      "side": 1,
      "message": "i think we want to return it even if it is not finalized, since we never want to overwrite an existing invocation",
      "range": {
        "startLine": 77,
        "startChar": 15,
        "endLine": 77,
        "endChar": 48
