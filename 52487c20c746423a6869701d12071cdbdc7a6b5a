      },
      "writtenOn": "2018-04-20T20:34:16Z",
      "side": 1,
      "message": "This is great, delegating to the proto code for text output instead of maintaining a custom version (like skylarkstruct.to_proto does)",
      "range": {
        "startLine": 37,
        "startChar": 24,
        "endLine": 37,
        "endChar": 52
      },
      "revId": "52487c20c746423a6869701d12071cdbdc7a6b5a",
