        "id": 1114299
      },
      "writtenOn": "2020-03-17T23:53:31Z",
      "side": 1,
      "message": "package doc says\n\n\u003e WARNING: This package should only ever be imported by generated messages. The compatibility agreement covers nothing except for functionality needed to keep existing generated messages operational. Breakages that occur due to unauthorized usages of this package are not the author\u0027s responsibility.\n\nis there a better way?",
      "range": {
        "startLine": 57,
        "startChar": 37,
        "endLine": 57,
        "endChar": 46
      },
      "revId": "20789ef3eb73fd199659a4b06d2f948cc752c452",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
