        "id": 1003211
      },
      "writtenOn": "2019-11-09T01:33:47Z",
      "side": 1,
      "message": "IMO you don\u0027t need the URL at all (same below). URLs elsewhere are to get valid values, the enum lists all the valid values.",
      "parentUuid": "5610fe42_2b1a81ad",
      "revId": "d6bd5b566c3addc0c3e83d72aea68c68cbecd44f",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
