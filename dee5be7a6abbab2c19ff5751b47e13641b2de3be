      "writtenOn": "2018-05-11T13:37:18Z",
      "side": 1,
      "message": "nit: consider casting \"lst.TerminalIndex\" to a types.MessageIndex, instead of the other way around. The only reason it\u0027s an \"int64\" is b/c this is a datastore struct, and so uses datastore types.",
      "range": {
        "startLine": 178,
        "startChar": 45,
        "endLine": 178,
        "endChar": 62
      },
      "revId": "dee5be7a6abbab2c19ff5751b47e13641b2de3be",
