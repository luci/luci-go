    {
      "key": {
        "uuid": "17d69e96_e02d5759",
        "filename": "milo/frontend/ui/build.go",
        "patchSetId": 12
      },
      "lineNbr": 98,
      "author": {
        "id": 1002080
      },
      "writtenOn": "2018-12-17T20:19:47Z",
      "side": 1,
      "message": "I don\u0027t think it\u0027s unrealistic.  build.proto is user data, and Milo should behave well even with invalid user data.  It could panic, but at least panic with a better message than \"segfault\" or something.",
      "parentUuid": "17a05570_de9e5356",
      "range": {
        "startLine": 98,
        "startChar": 28,
