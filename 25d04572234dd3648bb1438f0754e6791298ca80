      "writtenOn": "2017-12-09T01:58:41Z",
      "side": 1,
      "message": "additions do not need a map. they can stay they way they are. Same for removals.\nhow determinism for updates important?",
      "parentUuid": "e41e22bb_e80ca989",
      "range": {
        "startLine": 28,
        "startChar": 0,
        "endLine": 32,
        "endChar": 1
      },
