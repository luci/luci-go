      "lineNbr": 173,
      "author": {
        "id": 1001907
      },
      "writtenOn": "2018-11-16T00:42:59Z",
      "side": 1,
      "message": "good thing StreamChunkCallback is called under a lock!\n\nThat said, I would short circuit if le is NOT partial and buf is empty, call cb(le) and return (no extra allocs, logic). We expect this to be the majority case anyway, right?",
      "range": {
        "startLine": 173,
        "startChar": 3,
        "endLine": 173,
        "endChar": 24
      },
      "revId": "1847cdcf2e649bbc021ec35b5643f3a50cac041a",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
