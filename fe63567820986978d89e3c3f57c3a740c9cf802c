      "writtenOn": "2019-08-08T19:08:20Z",
      "side": 1,
      "message": "reflect.ValueOf(ptrOfThing).Pointer() -\u003e uintptr?\n\nno unsafe code necessary",
      "range": {
        "startLine": 61,
        "startChar": 3,
        "endLine": 62,
        "endChar": 18
