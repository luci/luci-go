      "writtenOn": "2019-08-08T19:08:20Z",
      "side": 1,
      "message": "can we? What about repeated message fields? In python protobuf it has a custom lazy List implementation for this purpose\n\nWhy is an internal lock insufficient?",
      "range": {
        "startLine": 194,
        "startChar": 31,
        "endLine": 195,
        "endChar": 22
      },
      "revId": "fe63567820986978d89e3c3f57c3a740c9cf802c",
