    {
      "key": {
        "uuid": "b37d6bbc_b3c9af16",
        "filename": "buildbucket/proto/launcher.proto",
        "patchSetId": 4
      },
      "lineNbr": 46,
      "author": {
        "id": 1001907
      },
      "writtenOn": "2019-04-23T18:31:40Z",
      "side": 1,
      "message": "I was thinking this structure would allow us to explicitly scope service specific parameters, instead of having service_value options in the top level message. It means that when we need to add additional parameters the scope is obvious. I thought this would be for the same reason that you use \u0027google.protobuf.Empty\u0027 instead of bool above (i.e. a small amount of future proofing)",
      "parentUuid": "1f3b41b3_0b207cf4",
      "range": {
        "startLine": 46,
        "startChar": 9,
        "endLine": 46,
        "endChar": 25
      },
      "revId": "37f262445567f3169ec7deb81b91ba59843ca8f1",
