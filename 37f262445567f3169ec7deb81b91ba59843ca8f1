      "writtenOn": "2019-04-23T02:33:52Z",
      "side": 1,
      "message": "why?\n\nshould build belong to Buildbucket? Should we add swarming for caches?\n\nmaybe keep it simple?",
      "parentUuid": "cd4838a7_b7913315",
      "range": {
        "startLine": 46,
        "startChar": 9,
        "endLine": 46,
        "endChar": 25
      },
      "revId": "37f262445567f3169ec7deb81b91ba59843ca8f1",
