      "unresolved": true
    },
    {
      "key": {
        "uuid": "81b86f13_d592a072",
        "filename": "buildbucket/proto/launcher.proto",
        "patchSetId": 4
      },
      "lineNbr": 46,
      "author": {
        "id": 1114299
      },
      "writtenOn": "2019-04-25T01:59:35Z",
      "side": 1,
      "message": "i started implementing your proposal, but this does not look right. By this logic, build field should in buildbucket (see comment above), but it does not make sense because only buildbucket has build and no other LUCI service is going to have builds (say we introduce DM, then it would be quest). So I am not sure I buy the argument that we\u0027d be adding \"service_value\" fields. I think we\u0027d be adding \"value\" fields (like \"build\", as opposed to \"buildbucket_build\"). It is the hostname that is special here. Imagine that one day we have buildbucket.\u003cluci_deployment_host\u003e and logdog.\u003cluci_deployment_host\u003e. Then we don\u0027t need by-service separation. In other words, I think we should continue pursuing the idea that we should hide/encapsulate the fact that LUCI happens to be implemented as a set of separate micro-services. It is an impl detail.",
      "parentUuid": "b37d6bbc_b3c9af16",
      "range": {
        "startLine": 46,
        "startChar": 9,
        "endLine": 46,
        "endChar": 25
      },
