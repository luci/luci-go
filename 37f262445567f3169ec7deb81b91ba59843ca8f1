    {
      "key": {
        "uuid": "2b03403b_ecaecbca",
        "filename": "buildbucket/runbuild/runbuild.go",
        "patchSetId": 4
      },
      "lineNbr": 148,
      "author": {
        "id": 1114299
      },
      "writtenOn": "2019-04-23T02:33:52Z",
      "side": 1,
      "message": "confused. How do you suggest to compare to? there is only one channel from a subprocess to runbuild. Whatever was most recent is the final build.",
      "parentUuid": "ca247ede_bad526ee",
      "range": {
        "startLine": 148,
        "startChar": 21,
        "endLine": 148,
        "endChar": 26
      },
      "revId": "37f262445567f3169ec7deb81b91ba59843ca8f1",
