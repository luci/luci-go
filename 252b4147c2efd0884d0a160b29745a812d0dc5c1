      },
      "writtenOn": "2021-03-18T21:59:32Z",
      "side": 1,
      "message": "I feel like using string here is better because\n  1. in the future, CV can just copy the mode value to here.\n  2. IIUC, this is internal as only cv/cq recipe module will parse this proto message and expose information via module api. We can convert it to enum if needed there.",
      "range": {
        "startLine": 52,
        "startChar": 2,
        "endLine": 52,
        "endChar": 22
      },
      "revId": "252b4147c2efd0884d0a160b29745a812d0dc5c1",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba"
    },
    {
      "unresolved": true,
      "key": {
        "uuid": "3dd6f8fd_7529a913",
        "filename": "cv/api/recipe/v1/cq.proto",
        "patchSetId": 1
      },
      "lineNbr": 52,
