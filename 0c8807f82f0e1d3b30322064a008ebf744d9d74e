      "side": 1,
      "message": "whether test is expected is orthogonal to whether it was exonerated. why do need this?",
      "range": {
        "startLine": 119,
        "startChar": 1,
        "endLine": 121,
        "endChar": 2
      },
      "revId": "0c8807f82f0e1d3b30322064a008ebf744d9d74e",
