    {
      "key": {
        "uuid": "2bfc4abb_eb3d3c3d",
        "filename": "resultdb/cmd/backend/bigquery_export.go",
        "patchSetId": 4
      },
      "lineNbr": 121,
      "author": {
        "id": 1157909
      },
      "writtenOn": "2020-01-15T19:08:24Z",
      "side": 1,
      "message": "I think it would be confusing for an expected test result to be marked as \u0027exonerated\u0027.",
      "parentUuid": "e9998fbf_9158f01f",
      "range": {
        "startLine": 119,
        "startChar": 1,
        "endLine": 121,
        "endChar": 2
      },
      "revId": "0c8807f82f0e1d3b30322064a008ebf744d9d74e",
