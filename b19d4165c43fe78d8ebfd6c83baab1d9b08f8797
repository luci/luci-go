      "message": "nit: it *feels* like this code could be even simpler :)\n\ncurrently this func has two deal with *two* states: Data and Meta, although it could be just one. \n\n  func (u *artifactUploader) makeBatches(maxSum int64, tasks []interface{}) (*pb.BatchCreateArtifactsRequest, error) {\n    ...\n  }\n\nand then this func could be\n\n\n  func (u *artifactUploader) BatchUpload(ctx context.Context, b *buffer.Batch) error {\n    var err error\n    if b.Meta \u003d\u003d nil {\n      if b.Meta, err \u003d u.makeBatches(b.Data); err !\u003d nil {\n        return err...\n      }\n    }\n\n    reqs :\u003d b.Meta.([]*pb.BatchCreateArtifactsRequest)\n    for len(reqs) \u003e 0 {\n      if _, err :\u003d u.Recorder.BatchCreateArtifacts(ctx, reqs[0]); err !\u003d nil {\n        return err\n      }\n      reqs \u003d reqs[1:]\n      b.Meta \u003d reqs\n    }\n    return nil\n  }",
