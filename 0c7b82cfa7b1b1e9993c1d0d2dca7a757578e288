      "writtenOn": "2020-01-23T21:37:07Z",
      "side": 1,
      "message": "this does not prepend context to the returned error. e.g. when validating an artifact, the error message may be \"unspecified\" because name was unspecified. consider:\n\n\ntype checker struct {\n\terr *error\n}\n\nfunc (c *checker) Check(err error, format string, args ...interface{}) bool {\n\tif *c.err !\u003d nil {\n\t\treturn false\n\t}\n\tif err !\u003d nil {\n\t\t*c.err \u003d errors.Annotate(err, format, args...).Err()\n\t\treturn false\n\t}\n\treturn true\n}\n\nc :\u003d checker{\u0026err}\nswitch {\n\tcase c.Check(ValidateArtifactName(art.Name), \"name\"):\n\tcase c.Check(ValidateArtifactFetchUrl(art.FetchUrl), \"fetch_url\"):\n\t\t// skip `FetchUrlExpiration`\n\t\t// skip `ContentType`\n\t\t// skip `Size`\n\t\tbreak\n\t}",
      "range": {
