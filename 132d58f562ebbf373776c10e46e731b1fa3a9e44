    {
      "key": {
        "uuid": "7e9736a6_e6b8ad18",
        "filename": "server/server.go",
        "patchSetId": 5
      },
      "lineNbr": 182,
      "author": {
        "id": 1002539
      },
      "writtenOn": "2020-01-22T02:04:25Z",
      "side": 1,
      "message": "I don\u0027t think there\u0027s dev appserver, since GCP wants GAE apps to be like regular server-side processes.\n\nhttps://cloud.google.com/appengine/docs/standard/go/testing-and-deploying-your-app\n\n\"\"\"\nTo test your application\u0027s functionality before deploying, run your application in your local environment with the development tools that you usually use. For example, the go run command.\n\"\"\"\n\nThis is what **not passing** -prod is for. It makes logging output readable and sets up some (generally unsecure) defaults for otherwise necessary CLI flags (like -auth-service-host). This makes it easy to run app locally to hack on it.",
      "parentUuid": "91c27270_c14f8ad8",
      "range": {
        "startLine": 182,
        "startChar": 45,
        "endLine": 182,
        "endChar": 52
      },
