      "author": {
        "id": 1114299
      },
      "writtenOn": "2019-10-29T01:22:29Z",
      "side": 1,
      "message": "why is this needed?",
      "revId": "0a2b2651901999733141811eafb01f1bde201e0b",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
