    {
      "key": {
        "uuid": "cf1502b0_93c87333",
        "filename": "common/flag/commalist_test.go",
        "patchSetId": 1
      },
      "lineNbr": 47,
      "author": {
        "id": 1161844
      },
      "writtenOn": "2018-12-27T00:21:56Z",
      "side": 1,
      "message": "Because we use foo,bar format in all of our tools already.  I don\u0027t think it\u0027s worth surprising all of our users with a different format now.\n\n(I find the -list first -list second behavior to be unexpected.  Usually supplying a flag a second time overrides the first value.)",
      "parentUuid": "1c22d6d2_d2ffd095",
      "revId": "d9df298682cc8dc9254f67a2255f1cc90c6a11c9",
