        "id": 1161844
      },
      "writtenOn": "2018-12-27T00:21:56Z",
      "side": 1,
      "message": "The pointer is necessary because otherwise it cannot be changed when passed as an argument.\nThe struct is necessary because I don\u0027t want this to be interchangeable as a slice.\nIf I make this a slice now, it can\u0027t be made into not a slice without breaking backward compatibility.\n\nConversely, I can make this into a slice going forward since it has no exported struct fields.",
      "parentUuid": "22baa949_c06e7c48",
      "range": {
        "startLine": 26,
        "startChar": 3,
        "endLine": 26,
        "endChar": 4
      },
      "revId": "d9df298682cc8dc9254f67a2255f1cc90c6a11c9",
