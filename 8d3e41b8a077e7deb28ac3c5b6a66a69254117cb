    {
      "key": {
        "uuid": "3ea96c8e_83b846c1",
        "filename": "cq/api/bigquery/attempt.proto",
        "patchSetId": 2
      },
      "lineNbr": 72,
      "author": {
        "id": 1114919
      },
      "writtenOn": "2019-12-20T19:38:30Z",
      "side": 1,
      "message": "if CQ doesn\u0027t know result, then yes. \nBut if CQ knows the submission didn\u0027t succeed nor permanently fail (e.g. Gerrit raised 429 out of quota), then this status is used.\n\nSuggestions for rephrasing the above comment?",
      "parentUuid": "96fb08fe_ba2484d1",
      "range": {
        "startLine": 72,
        "startChar": 35,
        "endLine": 72,
        "endChar": 73
      },
      "revId": "8d3e41b8a077e7deb28ac3c5b6a66a69254117cb",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
