      "writtenOn": "2019-12-20T18:18:10Z",
      "side": 1,
      "message": "since there\u0027s a UNKNOWN value below, if submission was tried at all but we don\u0027t know the final result, maybe UNKNOWN should be used?",
      "range": {
        "startLine": 72,
        "startChar": 35,
        "endLine": 72,
        "endChar": 73
      },
      "revId": "8d3e41b8a077e7deb28ac3c5b6a66a69254117cb",
