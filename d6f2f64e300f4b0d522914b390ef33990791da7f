      "writtenOn": "2018-01-22T23:43:05Z",
      "side": 1,
      "message": "i mistyped, sorry. I meant that this constraint is a relaxed version of UNIQUE (name, vlan_id)",
      "parentUuid": "73d72937_05cb1b13",
      "revId": "d6f2f64e300f4b0d522914b390ef33990791da7f",
