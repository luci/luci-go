    {
      "key": {
        "uuid": "1f0f0e6c_b57dde04",
        "filename": "resultdb/sink/gs_channel.go",
        "patchSetId": 7
      },
      "lineNbr": 67,
      "author": {
        "id": 1147264
      },
      "writtenOn": "2020-04-01T01:21:22Z",
      "side": 1,
      "message": "There is no busy waiting, as gsc.findUploadTask() does select{} on the channel and context.\n\nWG is to ensure that all the in-flight requests are completed before closing drainCh so that closeAndDrain() will be unblocked.",
      "parentUuid": "8462d8de_7740e440",
      "revId": "7380bf4f7f3abc34611f180db025d5c8f8f67a9d",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
