      "writtenOn": "2020-11-02T23:51:22Z",
      "side": 1,
      "message": "Happy to distinguish those two! Could you give me an example, in this CL, that is not permanently needed?",
      "parentUuid": "020892d9_688511cb",
      "revId": "685ae912a3f4371c3dfa2fd9ea5292076d78864d",
