    {
      "key": {
        "uuid": "83e26964_a79c5b38",
        "filename": "machine-db/appengine/model/datacenters/datacenters.go",
        "patchSetId": 1
      },
      "lineNbr": 242,
      "author": {
        "id": 1114299
      },
      "writtenOn": "2017-12-06T07:44:48Z",
      "side": 1,
      "message": "i think this does not belong to EnsureDatacenters, but to the caller.\nEnsureDatacenters should probably ensure only datacenters.\n\nin general, this won\u0027t approach if a table has two foreign keys, e.g. images tables t1, t2, t3 where t3 has foreign keys to t1 and t2. We cannot call EnsureT3() from EnsureT1() because t2 might be not initialized yet. If we call EnsureT3() from EnsureT2() then we implicitly assume that t1 was already initialized.\n\nbesides, the order of updates would be more obvious if code went like\n\n  EnsureT1()\n  EnsureT2()\n  EnsureT3()",
      "revId": "2e46b4c8c2d47084fa5b419ed482e61db80fb1d9",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
