    {
      "key": {
        "uuid": "ffdabe54_6cc166a7",
        "filename": "milo/frontend/view_build.go",
        "patchSetId": 1
      },
      "lineNbr": 85,
      "author": {
        "id": 1178685
      },
      "writtenOn": "2019-11-13T04:17:12Z",
      "side": 1,
      "message": "I think this is to prevent firing multiple requests accidentally. (I\u0027m assuming) If the server receives a request of a same ID within certain time span, the 2nd request will not trigger a retry. In this case, a random ID is good enough. Probably need tandrii@ or nodir@ to confirm that.",
      "parentUuid": "e837b8d9_3b348e44",
      "range": {
        "startLine": 85,
        "startChar": 20,
        "endLine": 85,
        "endChar": 32
      },
      "revId": "740ae4a67001dc33ca89e64e98ec1d75f9daee50",
