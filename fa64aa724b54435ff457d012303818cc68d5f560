    {
      "key": {
        "uuid": "97ae360d_da2dd241",
        "filename": "milo/api/config/settings.proto",
        "patchSetId": 1
      },
      "lineNbr": 57,
      "author": {
        "id": 1141499
      },
      "writtenOn": "2018-05-15T21:54:12Z",
      "side": 1,
      "message": "I considered this actually and was on the fence, but chose against extra embedded message for 2 reasons:\n1. We have config validation (or will have in next CL)\n2. With extra message, config is less readable and takes more effort to write.\nTo me these two things are better than guaranteed hardness of misuse (note that we still have to validate that say hostname is never empty)\nDoes this change your opinion?",
      "parentUuid": "58c43a36_8fe5cf28",
