      "writtenOn": "2019-11-12T19:42:10Z",
      "side": 1,
      "message": "I saw that mutateInvocation happens after insertTestExoneration in multiple places, if that\u0027s always true, should we consider wrapping this dependency in a function?",
      "range": {
        "startLine": 60,
        "startChar": 0,
        "endLine": 63,
        "endChar": 3
      },
      "revId": "81fc2e924d18d19d17260725d3ab57c8d478a92d",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
