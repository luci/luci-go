    },
    {
      "key": {
        "uuid": "c3dcdd2a_2fe7f6f3",
        "filename": "resultdb/cmd/recorder/create_test_exoneration.go",
        "patchSetId": 4
      },
      "lineNbr": 63,
      "author": {
        "id": 1114299
      },
      "writtenOn": "2019-11-12T19:56:03Z",
      "side": 1,
      "message": "insertTestExoneration only creates an insertion mutation but does not actually communicate with database. I understand that this is confusing, but this is also consistent with spanner API, e.g. https://godoc.org/cloud.google.com/go/spanner#Insert does not actually insert anything yet",
      "parentUuid": "566975a6_47eb402b",
      "range": {
        "startLine": 60,
        "startChar": 0,
        "endLine": 63,
        "endChar": 3
      },
      "revId": "81fc2e924d18d19d17260725d3ab57c8d478a92d",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
    {
      "key": {
        "uuid": "1ef1cdf4_e751a77e",
        "filename": "resultdb/cmd/recorder/create_test_exoneration.go",
