      "author": {
        "id": 1002080
      },
      "writtenOn": "2018-12-15T00:21:58Z",
      "side": 1,
      "message": "Done, a new key is created for every retry.",
      "parentUuid": "ab959bd1_7d56ebc2",
      "range": {
        "startLine": 90,
        "startChar": 5,
        "endLine": 90,
        "endChar": 50
      },
      "revId": "a1e3b995ee157d86aa5e66ee6937f3f48c9c6da2",
