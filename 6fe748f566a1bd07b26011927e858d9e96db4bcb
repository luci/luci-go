      "writtenOn": "2020-04-09T23:18:44Z",
      "side": 1,
      "message": "\u003e concrete reason: we don\u0027t fully own schemas of these tables. \n\nI think we do own the table schema? We don\u0027t fully own the results to be exported, but the schema should be the same?",
      "parentUuid": "d8c50a16_56befd8b",
      "revId": "6fe748f566a1bd07b26011927e858d9e96db4bcb",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
