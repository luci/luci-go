      "writtenOn": "2020-04-08T17:33:19Z",
      "side": 1,
      "message": "(Probably in a separate CL) Should we export this field to Big Query?",
      "revId": "6fe748f566a1bd07b26011927e858d9e96db4bcb",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
