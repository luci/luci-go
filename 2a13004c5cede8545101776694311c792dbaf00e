      "writtenOn": "2021-02-04T01:45:11Z",
      "side": 1,
      "message": "why do we ask for CreateArtifactRequest.invocation then?",
      "range": {
        "startLine": 285,
        "startChar": 2,
        "endLine": 286,
        "endChar": 29
      },
      "revId": "2a13004c5cede8545101776694311c792dbaf00e",
