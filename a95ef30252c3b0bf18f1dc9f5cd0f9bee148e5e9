      "writtenOn": "2021-04-30T21:30:17Z",
      "side": 1,
      "message": "My reading of buffer.Options{} doc is that this should panic.",
      "range": {
        "startLine": 66,
        "startChar": 4,
        "endLine": 66,
        "endChar": 63
      },
      "revId": "a95ef30252c3b0bf18f1dc9f5cd0f9bee148e5e9",
