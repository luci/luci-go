    {
      "key": {
        "uuid": "e5f63f5e_2f178233",
        "filename": "buildbucket/appengine/model/utils.go",
        "patchSetId": 4
      },
      "lineNbr": 57,
      "author": {
        "id": 1398165
      },
      "writtenOn": "2020-06-17T01:12:00Z",
      "side": 1,
      "message": "The comments are copied from python but doesn\u0027t very make sense to readers. \nBut these comments are necessary to understand the logic. So I rephrased it in new patchset.\n\nIt still converts the [low, high) to [low, high). Explanation see below.",
      "parentUuid": "66f175d0_b4144353",
      "revId": "8759ed1f1d9ef24d764722d5215b36fb510c2efd",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
