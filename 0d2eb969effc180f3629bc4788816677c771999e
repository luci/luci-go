        "id": 1002539
      },
      "writtenOn": "2017-08-31T22:38:46Z",
      "side": 1,
      "message": "This sounds odd... I assumed it is repeated to allow to check a bunch of resources at once.",
      "range": {
        "startLine": 99,
        "startChar": 56,
        "endLine": 99,
        "endChar": 74
      },
      "revId": "0d2eb969effc180f3629bc4788816677c771999e",
