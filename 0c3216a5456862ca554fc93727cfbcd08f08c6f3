      "writtenOn": "2017-11-15T01:03:38Z",
      "side": 1,
      "message": "consider naming it Get() or DB(), because in most cases it will be called using \u003cpackage name\u003e.\n\ndatabase.Get(c) or database.DB(c) looks nicer than database.GetDatabase(c)\n\n(see https://blog.golang.org/package-names in particular \"Avoid stutter\")",
      "range": {
        "startLine": 96,
        "startChar": 5,
        "endLine": 96,
        "endChar": 16
      },
      "revId": "0c3216a5456862ca554fc93727cfbcd08f08c6f3",
