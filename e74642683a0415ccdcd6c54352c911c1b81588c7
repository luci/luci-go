      "writtenOn": "2017-10-05T20:03:07Z",
      "side": 1,
      "message": "this might be cleaner if this was just\n\n  repeated RegisterStreamRequest ...\n  repeated LoadStreamRequest ...\n  repeated TerminateStreamRequest ...\n  repeated ArchiveStreamRequest ...\n\n?",
      "revId": "e74642683a0415ccdcd6c54352c911c1b81588c7",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
